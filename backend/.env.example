PORT=5000
# Local MongoDB (requires MongoDB installed):
MONGODB_URI=mongodb://localhost:27017/tracy-shop
# Or use MongoDB Atlas free tier:
# MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/tracy-shop
JWT_SECRET=tracy-shop-super-secret-key-change-in-production
JWT_EXPIRES_IN=7d

# Twilio SendGrid — email connector
# Obtain your API key from https://app.sendgrid.com/settings/api_keys
SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Verified sender address configured in your SendGrid account
SENDGRID_FROM_EMAIL=no-reply@tracy-shop.example.com
# Base URL of the frontend (used to build password-reset links)
FRONTEND_URL=http://localhost:3000
